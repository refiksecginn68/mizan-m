{
  "manifest_version": 3,
  "name": "Mizanım UYAP Aktarım",
  "version": "1.0.0",
  "description": "UYAP Avukat Portal'da açık dosyalarınızı Mizanım'a aktarır. Otomatik giriş yapmaz; yalnızca sizin açtığınız oturumu okur.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*.uyap.gov.tr/*",
    "https://*.xn--mizanm-t9a.com/*",
    "https://xn--mizanm-t9a.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.uyap.gov.tr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mizanım'a Aktar"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
